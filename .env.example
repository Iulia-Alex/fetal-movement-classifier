# Copy this file to .env and adjust the paths for your environment.
# These variables are read by src/config.py; all path constants in the code derive from them.

# Root directory of the fECG_approx working tree (model checkpoints, results, cached signals)
FECG_ROOT=/path/to/fECG_approx

# Root directory of the movement ECG database (DB_1, Final_Test_DB_npy, Test_DB)
FECG_DATA_ROOT=/path/to/fECG_mvm_DB
